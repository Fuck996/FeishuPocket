# FeishuPocket Environment Configuration
# 复制为 .env 并填入必要配置
# 注：飞书 webhook、模型 API 密钥等由管理员在系统 UI 中设置

# Node 运行时
NODE_ENV=production
PORT=3000
TZ=Asia/Shanghai
# 数据库路径（通常无需修改）
DATABASE_PATH=/app/data/store.json

# 容器部署参数
APP_PORT=45174

# 群菜单中转页外网基地址（飞书群菜单 redirect_link 前缀）
# 示例：https://pocket.example.com
MENU_BRIDGE_BASE_URL=
