# FeishuPocket Environment Configuration
# 复制为 .env 并填入真实的值

# Node 运行时
NODE_ENV=production
PORT=3000
TZ=Asia/Shanghai

# JWT 密钥（必填）
# 重要：必须生成强随机密钥
# 生成方法：openssl rand -base64 32
JWT_SECRET=change-me-to-a-strong-random-secret

# 飞书群机器人（必填）
# 从飞书机器人配置获取回调地址
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_key

# 默认模型配置
# DeepSeek API 密钥（可选）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# 备用：OpenAI API 密钥（可选）
# OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# 备用：Google API 密钥（可选）
# GOOGLE_API_KEY=your-google-api-key-here

# 数据库路径（通常无需修改）
DATABASE_PATH=/app/data/store.json

# 容器部署参数
APP_PORT=45174
IMAGE_NAMESPACE=Fuck996
IMAGE_TAG=v0.2.1
