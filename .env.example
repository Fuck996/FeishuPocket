# FeishuPocket Environment Configuration
# 复制为 .env 并填入必要配置
# 注：飞书 webhook、模型 API 密钥等由管理员在系统 UI 中设置

# Node 运行时
NODE_ENV=production
PORT=3000
TZ=Asia/Shanghai

# JWT 密钥（必填）
# 重要：必须生成强随机密钥
# 生成方法：openssl rand -base64 32
JWT_SECRET=change-me-to-a-strong-random-secret

# 数据库路径（通常无需修改）
DATABASE_PATH=/app/data/store.json

# 容器部署参数
APP_PORT=45174
IMAGE_NAMESPACE=Fuck996
IMAGE_TAG=v0.2.1
